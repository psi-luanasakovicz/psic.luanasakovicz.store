# Supabase — copie para .env.local e preencha com os dados do seu projeto
# Use a chave "anon public" (JWT eyJ...) OU a publishable key (sb_publishable_...)
# Dashboard: Settings → API → Project API keys

NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-publica

# Compra simulada (opcional). Padrão: ativa só em NODE_ENV=development.
# NEXT_PUBLIC_ENABLE_SIMULATED_CHECKOUT=true

# Mercado Pago (checkout real em sandbox ou produção)
# Credenciais: https://www.mercadopago.com.br/developers/panel/app
# Use o Access Token de TESTE para sandbox (começa com TEST-)
MERCADOPAGO_ACCESS_TOKEN=TEST-seu-access-token
# NEXT_PUBLIC_ENABLE_MERCADOPAGO_CHECKOUT=true
# URL pública do site (obrigatório em produção para back_urls e webhook)
# NEXT_PUBLIC_SITE_URL=https://psic-luanasakovicz-store.vercel.app
# Chave service_role do Supabase (Settings → API) — usada no webhook para liberar acesso
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Token do app interativo (baralho). Gere uma string longa e aleatória.
# Use o MESMO valor na Vercel. O baralho valida via /api/interactive-app/verify
INTERACTIVE_APP_SECRET=defina-uma-chave-secreta-longa-aqui
